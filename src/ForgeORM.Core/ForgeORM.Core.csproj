<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>ForgeORM.Core</PackageId>
         <Version>1.3.7</Version>
    <Authors>Raheel Ahmed</Authors>
    <Company>Forge Ecosystem</Company>
    <RepositoryUrl>https://github.com/ahmedraheel/ForgeORM</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://www.developerslabai.com/#forgeorm-full-wiki</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>forgeorm-icon.png</PackageIcon>
    <PackageTags>orm;micro-orm;micro-orm;efcore;sql;database;query-builder;bulk;dotnet;forgeorm</PackageTags>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <Title>ForgeORM.Core</Title>
    <Description>Core ForgeORM runtime with native ADO.NET SQL execution, repository helpers, transactions, split queries and bulk hooks.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\ForgeORM.Abstractions\ForgeORM.Abstractions.csproj" />
    <ProjectReference Include="..\ForgeORM.QueryAst\ForgeORM.QueryAst.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\assets\forgeorm-icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" />
  </ItemGroup>

  <ItemGroup>
    <None Include="buildTransitive\$(PackageId).props" Pack="true" PackagePath="buildTransitive\$(PackageId).props" Visible="false" />
  </ItemGroup>
  <Target Name="ForgeORM_BuildAndPackSourceGeneratorAnalyzer" BeforeTargets="_GetPackageFiles;GenerateNuspec">
    <!--
      Build and pack the source generator into this NuGet package.
      End users never add analyzer paths manually; NuGet consumes this from analyzers/dotnet/cs.
    -->
    <PropertyGroup>
      <ForgeOrmSourceGeneratorTargetFramework Condition="'$(ForgeOrmSourceGeneratorTargetFramework)' == ''">netstandard2.0</ForgeOrmSourceGeneratorTargetFramework>
      <ForgeOrmSourceGeneratorProject>..\ForgeORM.SourceGenerators\ForgeORM.SourceGenerators.csproj</ForgeOrmSourceGeneratorProject>
      <ForgeOrmSourceGeneratorDll>..\ForgeORM.SourceGenerators\bin\$(Configuration)\$(ForgeOrmSourceGeneratorTargetFramework)\ForgeORM.SourceGenerators.dll</ForgeOrmSourceGeneratorDll>
    </PropertyGroup>

    <MSBuild Projects="$(ForgeOrmSourceGeneratorProject)"
             Targets="Build"
             Properties="Configuration=$(Configuration);TargetFramework=$(ForgeOrmSourceGeneratorTargetFramework)" />

    <Error Condition="!Exists('$(ForgeOrmSourceGeneratorDll)')"
           Text="ForgeORM.SourceGenerators.dll was not built/found at $(ForgeOrmSourceGeneratorDll)." />

    <ItemGroup>
      <None Include="$(ForgeOrmSourceGeneratorDll)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs"
            Visible="false" />
    </ItemGroup>
    <Message Importance="High" Text="ForgeORM: packing source generator analyzer $(ForgeOrmSourceGeneratorDll)" />
  </Target>
</Project>