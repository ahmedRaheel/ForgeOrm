<Project>
  <PropertyGroup Condition="'$(ForgeOrmDisableSourceGenerator)' != 'true'">
    <!-- SourceGenerated mode must work with only NuGet + DI. Force generators to run during normal builds. -->
    <RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
  </PropertyGroup>
  <!--
    Auto-wire ForgeORM source generation for NuGet consumers.
    User only calls: options.UseCompilationMode(SourceGenerated).
  -->
  <ItemGroup Condition="'$(ForgeOrmDisableSourceGenerator)' != 'true' and Exists('$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\ForgeORM.SourceGenerators.dll')">
    <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\ForgeORM.SourceGenerators.dll" />
  </ItemGroup>
</Project>
