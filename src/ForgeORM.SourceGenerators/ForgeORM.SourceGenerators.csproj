<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
   
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <DevelopmentDependency>true</DevelopmentDependency>
    <PackageId>ForgeORM.SourceGenerators</PackageId>
    <Description>Compile-time ForgeORM materializers and parameter binders that remove runtime reflection from hot paths.</Description>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageType>Analyzer</PackageType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
  </ItemGroup>

  <Target Name="ForgeORM_SourceGenerator_AddAnalyzerToPackage" BeforeTargets="_GetPackageFiles;GenerateNuspec" DependsOnTargets="Build">
    <ItemGroup Condition="Exists('$(TargetPath)')">
      <None Include="$(TargetPath)" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    </ItemGroup>
    <Error Condition="!Exists('$(TargetPath)')"
           Text="ForgeORM.SourceGenerators analyzer was not built at $(TargetPath)." />
  </Target>
</Project>
