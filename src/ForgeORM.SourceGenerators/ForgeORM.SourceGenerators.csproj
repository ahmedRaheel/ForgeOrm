<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <DevelopmentDependency>true</DevelopmentDependency>
    <PackageId>ForgeORM.SourceGenerators</PackageId>
    <Description>Compile-time ForgeORM materializers and parameter binders that remove runtime reflection from hot paths.</Description>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageType>Analyzer</PackageType>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
  </ItemGroup>
  <!--
    Pack the built analyzer DLL only after the generator has been compiled.
    Do not use $(OutputPath)$(AssemblyName).dll because SDK projects output to
    bin/<Configuration>/<TargetFramework>/ and Visual Studio may evaluate the
    item before the DLL exists, producing File not found errors.
  -->
  <Target Name="ForgeORM_SourceGenerator_AddAnalyzerToPackage" BeforeTargets="_GetPackageFiles;GenerateNuspec">
    <ItemGroup>
      <None Include="$(TargetPath)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs"
            Visible="false"
            Condition="Exists('$(TargetPath)')" />
    </ItemGroup>
    <Warning Condition="!Exists('$(TargetPath)')"
             Text="ForgeORM.SourceGenerators analyzer was not built at $(TargetPath). Run Build/Rebuild before packing this analyzer package." />
  </Target>

  <Target Name="ForgeORM_GetAnalyzerTargetPath" Returns="$(TargetPath)">
    <ItemGroup>
      <ForgeORM_SourceGeneratorTarget Include="$(TargetPath)" />
    </ItemGroup>
  </Target>
</Project>
